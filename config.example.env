# Example configuration template for calendar_bridge.py
# Copy this file to config.env and fill real values.

DB_FILE=sync_db.json
CREDENTIALS_FILE=credentials.json
WINDOW_PAST_DAYS=14
WINDOW_FUTURE_DAYS=365
DEFAULT_MAX_CREATE_CLONES_PER_RUN=50
DEFAULT_MAX_OUTLOOK_INVITES_PER_RUN=10

AUTH_PERSONAL_TOKEN_FILE=token_personal.json
AUTH_WORKSPACE_TOKEN_FILE=token_workspace.json

INVITE_ORGANIZER_AUTH_ACCOUNT_ID=personal
INVITE_ORGANIZER_CALENDAR_ID=primary

CLONE_SUMMARY=Busy (Synced)
BRIDGE_MARKER=CALBRIDGE_MANAGED=1

GOOGLE_PERSONAL_ID=google_personal
GOOGLE_PERSONAL_NAME=Personal Google
GOOGLE_PERSONAL_CALENDAR_ID=primary
GOOGLE_PERSONAL_READ_ENABLED=true
GOOGLE_PERSONAL_WRITE_ENABLED=true
GOOGLE_PERSONAL_MIRROR_SUMMARY=true
GOOGLE_PERSONAL_MIRROR_DESCRIPTION=false
GOOGLE_PERSONAL_SET_PRIVATE=false

GOOGLE_WORKSPACE_ID=google_workspace
GOOGLE_WORKSPACE_NAME=Workspace Google
GOOGLE_WORKSPACE_CALENDAR_ID=REPLACE_WITH_WORKSPACE_CALENDAR_ID
GOOGLE_WORKSPACE_READ_ENABLED=true
GOOGLE_WORKSPACE_WRITE_ENABLED=true
GOOGLE_WORKSPACE_MIRROR_SUMMARY=true
GOOGLE_WORKSPACE_MIRROR_DESCRIPTION=false
GOOGLE_WORKSPACE_SET_PRIVATE=true

OUTLOOK_ORG_ID=outlook_org
OUTLOOK_ORG_NAME=Outlook Org
OUTLOOK_ORG_ICS_URL=REPLACE_WITH_OUTLOOK_ICS_URL
OUTLOOK_ORG_INVITE_EMAIL=REPLACE_WITH_OUTLOOK_INVITE_EMAIL
OUTLOOK_ORG_READ_ENABLED=true
OUTLOOK_ORG_WRITE_ENABLED=true
OUTLOOK_ORG_MIRROR_SUMMARY=true
OUTLOOK_ORG_MIRROR_DESCRIPTION=false
OUTLOOK_ORG_SET_PRIVATE=false
